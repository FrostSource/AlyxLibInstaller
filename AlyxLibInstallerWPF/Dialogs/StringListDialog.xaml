<UserControl x:Class="AlyxLibInstallerWPF.Dialogs.StringListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:AlyxLibInstallerWPF.Converters"
             xmlns:local="clr-namespace:AlyxLibInstallerWPF.Dialogs"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="100">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <Geometry x:Key="DeleteIconGeometry">M 4,4 L 12,12 M 12,4 L 4,12</Geometry>
        <Geometry x:Key="TemporaryIconGeometry">M 8,2 A 6,6 0 1 1 3.2,4.4 M 2.75,2.75 L 2.75,5.75 L 5.75,5.75</Geometry>
    </UserControl.Resources>
    
    <Grid MaxWidth="400">
        <StackPanel Orientation="Vertical">
            <TextBlock Text="{Binding Message}"
                       Visibility="{Binding Message, Converter={StaticResource StringToVisibilityConverter}}"
                       Margin="0,0,8,8"
                       MaxWidth="{Binding ActualWidth, ElementName=StringListControl}"
                       TextWrapping="Wrap" />

            <WrapPanel Margin="0,0,0,8"
                       VerticalAlignment="Center"
                       Visibility="{Binding ActionLegendVisibility}">
                <Viewbox Width="14" Height="14" Margin="0,1,4,0">
                    <Path Data="{StaticResource DeleteIconGeometry}"
                          Stroke="{DynamicResource SystemFillColorCriticalBrush}"
                          StrokeThickness="1.8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" />
                </Viewbox>
                <TextBlock Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Delete" />

                <Viewbox Width="14" Height="14" Margin="0,1,4,0">
                    <Path Data="{StaticResource TemporaryIconGeometry}"
                          Stroke="{DynamicResource SystemFillColorCautionBrush}"
                          StrokeThickness="1.6"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round" />
                </Viewbox>
                <TextBlock VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Temp Move" />
            </WrapPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                <ItemsControl x:Name="StringListControl" MinWidth="300" ItemsSource="{Binding DisplayItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,1"
                                    Padding="8,4,16,4"
                                    CornerRadius="4"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                <DockPanel LastChildFill="True">
                                    <Grid Width="16"
                                          Height="16"
                                          Margin="0,1,8,0"
                                          VerticalAlignment="Top"
                                          ToolTip="{Binding ActionToolTip}">
                                        <Path
                                              Data="{StaticResource DeleteIconGeometry}"
                                              Stroke="{DynamicResource SystemFillColorCriticalBrush}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Action}" Value="{x:Static local:StringListItemAction.Delete}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        <Path
                                              Data="{StaticResource TemporaryIconGeometry}"
                                              Stroke="{DynamicResource SystemFillColorCautionBrush}"
                                              StrokeThickness="1.6"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Action}" Value="{x:Static local:StringListItemAction.TemporaryMove}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Grid>

                                    <TextBlock Text="{Binding Text}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</UserControl>
